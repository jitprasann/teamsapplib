{
  "name": "@microsoftlib/teams",
  "version": "1.0.0",
  "description": "Simplified wrapper around @microsoft/teams-js v2 SDK",
  "main": "dist/teams.cjs.js",
  "module": "dist/teams.esm.js",
  "browser": "dist/teams.umd.js",
  "exports": {
    ".": {
      "import": "./dist/teams.esm.js",
      "require": "./dist/teams.cjs.js",
      "default": "./dist/teams.umd.js"
    }
  },
  "scripts": {
    "build": "webpack --mode production",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": ["microsoft", "teams", "teams-js", "tab", "deeplink"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@microsoft/teams-js": "^2.0.0"
  },
  "peerDependencies": {
    "@microsoft/teams-js": "^2.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@microsoft/teams-js": "^2.0.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "terser-webpack-plugin": "^5.3.10",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^@microsoft/teams-js$": "<rootDir>/test/mocks/teams-js.mock.js"
    }
  }
}
